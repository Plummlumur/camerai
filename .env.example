COUNTER_SOURCE=sim
SENSOR_ID=raum-1
DB_PATH=data/raumzaehler.db
TIMEZONE=Europe/Vienna
INVERT_DIRECTION=false
NIGHTLY_RESET_TIME=04:00
LINE_POSITION=0.5
LINE_AXIS=x

# Camera preview (MJPEG) for setup/calibration. Off by default (privacy:
# raw video normally stays on the sensor). Only effective with the imx500 source.
CAMERA_PREVIEW_ENABLED=false
CAMERA_PREVIEW_FPS=10
CAMERA_PREVIEW_QUALITY=70
